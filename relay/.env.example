# Copy this to .env and fill in your M365 credentials.
# .env is gitignored and never committed.

M365_EMAIL=your-email@example.com
M365_PASSWORD=your-password

# Optional: use a different Chrome profile directory
# PROFILE_DIR=./profile

# Optional: set to false for visible browser during sign-in debugging
# HEADLESS=false

# OpenAI-compatible HTTP API
# OPENAI_API_PORT=9000
# OPENAI_API_HOST=0.0.0.0
# OPENAI_API_KEY=sk-change-me
# OPENAI_MAX_CHARS=100000
# Request audit log for rate-limit analysis
# REQUEST_LOG=./logs/requests.ndjson
# MAX_CONCURRENCY=10
