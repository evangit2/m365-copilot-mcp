# Runtime
.env
*.log
logs/
*.pid
node_modules/
.DS_Store
.vscode/
.idea/
Thumbs.db
profile/
profile-*/
screenshots/

# Hermes native plugin is symlinked from hermes-plugin/ into
# ~/.hermes/hermes-agent/plugins/m365_copilot_native. Source of truth is the
# hermes-plugin/ directory in this repo; ignore any local symlink copies.

# Relay lives inside this project so the whole stack is self-contained.
# Keep relay source committed but ignore runtime artifacts.
relay/node_modules/
relay/profile*/
relay/logs/
relay/screenshots/
relay/.cache/
relay/**/*.pid
relay/**/*.log
relay/**/.env
