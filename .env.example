# Microsoft 365 credentials (for automatic headless sign-in)
# Leave blank if you want to use VNC/manual sign-in mode.
M365_EMAIL=
M365_PASSWORD=

# Relay connection
RELAY_URL=http://127.0.0.1:9000
# Only needed if you enabled auth on the relay itself
RELAY_API_KEY=

# Path to the g365-headless-relay repo. install.sh clones it if missing.
# Default is inside this project so the MCP wrapper is self-contained.
G365_RELAY_REPO=$HOME/projects/m365-copilot-mcp/vendor/g365-headless-relay

# Authentication mode: credentials | vnc | existing
#   credentials = use M365_EMAIL + M365_PASSWORD for headless browser sign-in
#   vnc         = open VNC and ask user to sign in manually
#   existing    = assume relay is already running and signed in
AUTH_MODE=credentials

# Default Copilot model tone
M365_MODEL=gpt-5.5-think-deeper

# Relay HTTP server binding
OPENAI_API_PORT=9000
OPENAI_API_HOST=0.0.0.0

# Upstream concurrency cap
MAX_CONCURRENCY=10

# Chrome profile directory (gitignored by g365-headless-relay)
PROFILE_DIR=
